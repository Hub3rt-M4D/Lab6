# Copy this file to `.env` and paste your Google AI Studio key.
# Get one at: https://aistudio.google.com/app/apikey
#
# WARNING: This key ships to the browser (client-side, lab/demo setup).
# Anyone who opens the app can read it. Do NOT use a production / billed key.
VITE_GEMINI_API_KEY=your_key_here

# Optional overrides (defaults shown).
VITE_GEMINI_CHAT_MODEL=gemini-2.5-flash
VITE_GEMINI_EMBED_MODEL=text-embedding-004
